VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Requis uniquement pour lancer `npm run scan` en local (scripts/vinted-scan.ts).
# market_opportunities n'accepte plus les ecritures anonymes (voir DATABASE.md) --
# sans cette cle le scan echouera silencieusement a l'insertion.
SUPABASE_SERVICE_ROLE_KEY=

# Id de l'extension Chrome ResellOS (extension/), pour l'appairage depuis
# VintedAccountPage.tsx (voir src/lib/extensionBridge.ts). En dev, visible sur
# chrome://extensions une fois l'extension chargee via "Charger l'extension
# non empaquetee" -- change a chaque re-chargement non empaquete, stable une
# fois publiee sur le Chrome Web Store.
VITE_RESELLOS_EXTENSION_ID=
